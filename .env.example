# Environment Configuration for Decentralized Website Monitoring System

# Node Configuration
NODE_ID=node_1
NODE_HOST=localhost
NODE_PORT=8000
MONITORED_URLS=https://httpbin.org/status/200,https://google.com,https://github.com
MONITORING_INTERVAL=60

# Blockchain Configuration
ETHEREUM_RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=0xYourPrivateKeyHere
CONTRACT_ADDRESS=
CHAIN_ID=31337
GAS_LIMIT=200000
GAS_PRICE_GWEI=20

# Sepolia Testnet Configuration (uncomment to use)
# ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
# PRIVATE_KEY=YourSepoliaPrivateKey
# CHAIN_ID=11155111
# ETHERSCAN_API_KEY=YourEtherscanApiKey

# API Configuration
API_BASE_URL=http://localhost:8000

# Monitoring Configuration
MONITORING_TIMEOUT=10
MONITORING_MAX_RETRIES=3
MONITORING_WINDOW_SIZE=100
TRUST_DECAY_RATE=0.95

# ML Configuration
MODEL_PATH=./ml/models
ML_CONFIDENCE_THRESHOLD=0.7

# Dashboard Configuration
DASHBOARD_HOST=localhost
DASHBOARD_PORT=8501

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/node.log

# Peer Configuration
PEER_DISCOVERY_INTERVAL=300
PEER_HEALTH_CHECK_INTERVAL=60
MAX_PEERS=50

# Data Configuration
DATA_RETENTION_HOURS=24
BACKUP_INTERVAL_HOURS=6
